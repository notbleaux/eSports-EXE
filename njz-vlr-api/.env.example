# NJZ VLR API - Environment Configuration
# Copy this file to .env and fill in your values

# Core Settings
DEBUG=false
API_VERSION=2.0.0
PORT=3001
WORKERS=4

# VLR.gg Rate Limiting (Respectful defaults - DO NOT REDUCE)
VLR_REQUEST_DELAY=1.5
VLR_MAX_RETRIES=3
VLR_RETRY_BACKOFF=2.0
VLR_CONCURRENT_REQUESTS=2

# Data Storage
DATA_STORAGE_PATH=./data
RAWS_ENABLED=true
BASE_ENABLED=true

# Redis Cache (Optional but recommended)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/njz_vlr.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost/njz_vlr

# InfluxDB Time-Series (Optional)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influx-token
INFLUXDB_ORG=njz
INFLUXDB_BUCKET=vlr_data

# API Security (Enable for production)
API_KEY_REQUIRED=false
ALLOWED_API_KEYS=

# Webhook Secret (Generate strong random string)
WEBHOOK_SECRET=change-this-to-random-string-min-32-chars

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090