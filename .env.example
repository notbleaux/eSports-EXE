# NJZiteGeisTe Platform — Environment Variables
# Copy to .env.local and fill in your values
# Never commit .env.local to git

# ─── Database (Supabase) ───────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/njzitegeist
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=5

# ─── Cache (Redis / Upstash) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# ─── API Security ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=replace-with-32-plus-char-random-string

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ─── External Data APIs ───────────────────────────────────
PANDASCORE_API_KEY=your-pandascore-token-here

# ─── Frontend (Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_ENV=development

# ─── Environment ──────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
APP_VERSION=2.1.0

# ─── Observability / Distributed Tracing ──────────────────
# Enable/disable tracing
TRACING_ENABLED=true

# Service identification for traces
OTEL_SERVICE_NAME=njz-api
OTEL_SERVICE_VERSION=2.1.0
OTEL_ENVIRONMENT=development

# Tracing backend: jaeger, otlp_grpc, otlp_http, console
TRACING_BACKEND=jaeger

# Jaeger configuration (when TRACING_BACKEND=jaeger)
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# OTLP configuration (when TRACING_BACKEND=otlp_*)
# OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Sampling rate (1.0 = 100%, 0.1 = 10%, etc.)
OTEL_SAMPLE_RATE=1.0

# Export interval for batch span processor (ms)
OTEL_BATCH_SCHEDULE_DELAY=5000

# Max queue size for batch span processor
OTEL_MAX_QUEUE_SIZE=2048

# Max export batch size
OTEL_MAX_EXPORT_BATCH_SIZE=512

# Console output for debugging (set to true to see traces in logs)
TRACE_CONSOLE=false
