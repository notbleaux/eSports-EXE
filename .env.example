# =============================================================================
# SATOR-eXe-ROTAS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real secrets to git
# =============================================================================

# =============================================================================
# FRONTEND (VITE_) - These are exposed to the browser
# =============================================================================

# API endpoint for frontend requests
VITE_API_URL=https://api.libreauxnjz.io

# Application metadata
VITE_APP_NAME=SATOR Platform
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=NJZ eSports Analytics Platform

# Feature flags (optional)
VITE_ENABLE_ANALYTICS=true
VITE_DEBUG_MODE=false

# =============================================================================
# BACKEND API - Server-side only
# =============================================================================

# Database connection (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Redis cache (optional, for rate limiting)
REDIS_URL=redis://localhost:6379

# External API keys (CRITICAL for data collection)
PANDASCORE_API_KEY=your_pandascore_api_key_here
VLR_API_KEY=your_vlr_api_key_here

# Application configuration
API_PORT=8000
API_WORKERS=1
APP_ENVIRONMENT=development
LOG_LEVEL=info

# Security
SECRET_KEY=generate_a_random_secret_key_here
API_KEY_SALT=another_random_string

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BURST=5

# Data retention
DATA_RETENTION_DAYS=365

# =============================================================================
# DEPLOYMENT - CI/CD variables
# =============================================================================

# GitHub token (for automated deployments)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel token (for CLI deployments)
VERCEL_TOKEN=your_vercel_token_here

# Render API key (for infrastructure management)
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DEVELOPMENT - Local development only
# =============================================================================

# Local database (for development)
LOCAL_DATABASE_URL=postgresql://user:password@localhost:5432/sator_dev

# Enable hot reloading
HOT_RELOAD=true

# Debug logging
DEBUG=true
VERBOSE_LOGGING=false

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. Get PANDASCORE_API_KEY from: https://pandascore.co/dashboard
# 2. Get Supabase credentials from: https://app.supabase.com/project/_/settings/database
# 3. Generate SECRET_KEY with: openssl rand -hex 32
# 4. Never commit real values to git
# 5. Set production values in Vercel/Render dashboards
#
# =============================================================================
