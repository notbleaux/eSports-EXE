# =============================================================================
# SATOR-eXe-ROTAS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real secrets to git
# =============================================================================

# =============================================================================
# FRONTEND (VITE_) - These are exposed to the browser
# =============================================================================

# API endpoint for frontend requests
VITE_API_URL=https://api.libreauxnjz.io

# WebSocket URL for real-time updates
VITE_WS_URL=wss://api.libreauxnjz.io/v1/ws

# Application metadata
VITE_APP_NAME=SATOR Platform
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=NJZ eSports Analytics Platform

# Pandascore API Token (frontend)
# Get from: https://pandascore.co/dashboard
# Free tier: 1000 calls/day, 1 call/second
# Leave empty to use mock data
VITE_PANDASCORE_TOKEN=

# Riot Games API Key (frontend)
# WARNING: In production, API calls should go through backend proxy
# to protect your API key. Frontend direct access only for development.
# Get from: https://developer.riotgames.com/
VITE_RIOT_API_KEY=

# Riot API Proxy URL (recommended for production)
# Set this to your backend API that proxies Riot requests
VITE_RIOT_API_URL=http://localhost:8000/api/riot

# Feature flags (optional)
VITE_ENABLE_ANALYTICS=true
VITE_DEBUG_MODE=false

# =============================================================================
# BACKEND API - Server-side only
# =============================================================================

# CORS Origins - Comma-separated list of allowed origins
# For development: includes common localhost ports
# For production: set to your actual domain(s), e.g., "https://yourdomain.com,https://app.yourdomain.com"
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Database connection (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Redis cache (optional, for rate limiting)
REDIS_URL=redis://localhost:6379

# External API keys (CRITICAL for data collection)
PANDASCORE_API_KEY=your_pandascore_api_key_here
VLR_API_KEY=your_vlr_api_key_here

# Riot Games API Key
# Get from: https://developer.riotgames.com/
# Rate limits (Personal): 20 req/s, 100 req/2min
# Rate limits (Production): 500 req/10s, 30,000 req/10min
# Development keys expire every 24 hours and must be refreshed
RIOT_API_KEY=your_riot_api_key_here

# Riot API Region Configuration
# Options: na, latam, br, eu, ap, kr
RIOT_API_REGION=na
RIOT_API_SHARD=na

# Application configuration
API_PORT=8000
API_WORKERS=1
APP_ENVIRONMENT=development
LOG_LEVEL=info

# Security
# Generate with: openssl rand -hex 32
SECRET_KEY=generate_a_random_secret_key_here
API_KEY_SALT=another_random_string

# JWT Configuration (REQUIRED for production)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BURST=5

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_CONNECTION_TIMEOUT=300
WS_MAX_MESSAGE_SIZE=1048576

# Data retention
DATA_RETENTION_DAYS=365

# =============================================================================
# DEPLOYMENT - CI/CD variables
# =============================================================================

# GitHub token (for automated deployments)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel token (for CLI deployments)
VERCEL_TOKEN=your_vercel_token_here

# Render API key (for infrastructure management)
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DEVELOPMENT - Local development only
# =============================================================================

# Local database (for development)
LOCAL_DATABASE_URL=postgresql://user:password@localhost:5432/sator_dev

# Enable hot reloading
HOT_RELOAD=true

# Debug logging
DEBUG=true
VERBOSE_LOGGING=false

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. Get PANDASCORE_API_KEY from: https://pandascore.co/dashboard
# 2. Get RIOT_API_KEY from: https://developer.riotgames.com/
# 3. Get Supabase credentials from: https://app.supabase.com/project/_/settings/database
# 4. Generate SECRET_KEY with: openssl rand -hex 32
# 5. Never commit real values to git
# 6. Set production values in Vercel/Render dashboards
#
# =============================================================================
