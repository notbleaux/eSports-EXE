    {
      "name": "🏆 Tournaments",
      "item": [
        {
          "name": "List Tournaments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tournaments?game=valorant&page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tournaments"],
              "query": [
                {
                  "key": "game",
                  "value": "valorant",
                  "description": "Game filter: valorant or cs2"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "per_page",
                  "value": "20",
                  "description": "Items per page (max 100)"
                }
              ]
            },
            "description": "Get list of tournaments with pagination"
          },
          "response": []
        },
        {
          "name": "Get Tournament",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tournaments/{{tournament_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tournaments", "{{tournament_id}}"]
            },
            "description": "Get specific tournament by ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "⚔️ Matches",
      "item": [
        {
          "name": "Submit Match Result",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"match_id\": \"match_001\",\n  \"tournament_id\": \"{{tournament_id}}\",\n  \"team1_id\": \"team_alpha\",\n  \"team2_id\": \"team_beta\",\n  \"team1_score\": 13,\n  \"team2_score\": 10,\n  \"winner_id\": \"team_alpha\",\n  \"map_results\": [\n    {\n      \"map\": \"ascent\",\n      \"team1_score\": 13,\n      \"team2_score\": 10,\n      \"winner\": \"team_alpha\"\n    }\n  ],\n  \"stats\": {\n    \"team_alpha\": {\n      \"player_1\": {\n        \"kills\": 25,\n        \"deaths\": 15,\n        \"assists\": 5\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/matches/results",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tournaments", "{{tournament_id}}", "matches", "results"]
            },
            "description": "Submit match result (called by Godot game or admin)"
          },
          "response": []
        }
      ]
    },
