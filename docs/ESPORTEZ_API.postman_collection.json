    {
      "name": "🔔 Webhooks",
      "item": [
        {
          "name": "Pandascore Match Update",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Pandascore-Signature",
                "value": "sha256=example_signature",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"MATCH_END\",\n  \"id\": 12345,\n  \"match\": {\n    \"id\": 12345,\n    \"name\": \"Team A vs Team B\",\n    \"status\": \"finished\",\n    \"team1\": {\n      \"id\": 1,\n      \"name\": \"Team A\"\n    },\n    \"team2\": {\n      \"id\": 2,\n      \"name\": \"Team B\"\n    },\n    \"team1_score\": 13,\n    \"team2_score\": 10\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhooks/pandascore/match-update",
              "host": ["{{base_url}}"],
              "path": ["webhooks", "pandascore", "match-update"]
            },
            "description": "Receive Pandascore match update webhook"
          },
          "response": []
        },
