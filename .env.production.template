# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# NJZiteGeisTe Platform
# =============================================================================
# Copy this file and fill in your actual values
# NEVER commit real secrets to version control
# =============================================================================

# =============================================================================
# DATABASE (Supabase - Free Tier)
# Get from: https://app.supabase.com/project/_/settings/database
# =============================================================================
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Connection pool settings (optimized for free tier)
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=5
DB_POOL_TIMEOUT=30

# =============================================================================
# CACHE (Upstash - Free Tier)
# Get from: https://console.upstash.com
# =============================================================================
REDIS_URL=rediss://default:[PASSWORD]@[HOST]:[PORT]

# =============================================================================
# SECURITY KEYS (Generate with: openssl rand -hex 32)
# =============================================================================
JWT_SECRET_KEY=[GENERATE_64_CHAR_HEX_STRING]
TOTP_ENCRYPTION_KEY=[GENERATE_64_CHAR_HEX_STRING]
ENCRYPTION_KEY=[GENERATE_64_CHAR_HEX_STRING]

# =============================================================================
# APPLICATION CONFIG
# =============================================================================
APP_ENVIRONMENT=production
APP_NAME=SATOR-API
APP_VERSION=2.1.0
LOG_LEVEL=INFO
API_PORT=8000
API_WORKERS=1  # Free tier: single worker only

# =============================================================================
# CORS (Your actual frontend domains)
# =============================================================================
CORS_ORIGINS=https://sator-platform.vercel.app,https://sator-web.onrender.com

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=10

# =============================================================================
# EXTERNAL APIs (Optional - for live data)
# =============================================================================
# Pandascore: https://pandascore.co/dashboard (Free: 1000 calls/day)
PANDASCORE_API_KEY=[OPTIONAL]

# =============================================================================
# MONITORING (Optional - but recommended)
# =============================================================================
# Sentry: https://sentry.io (Free: 5000 errors/month)
SENTRY_DSN=[OPTIONAL]

# =============================================================================
# WEBSOCKET
# =============================================================================
WS_HEARTBEAT_INTERVAL=30
WS_CONNECTION_TIMEOUT=300
WS_MAX_MESSAGE_SIZE=1048576

# =============================================================================
# DEPLOYMENT
# =============================================================================
DEPLOYMENT_TYPE=free-tier

# =============================================================================
# NOTES
# =============================================================================
# 1. Generate secure keys: openssl rand -hex 32
# 2. Supabase free tier: 500MB storage, pauses after 7 days inactivity
# 3. Upstash free tier: 10,000 commands/day
# 4. Render free tier: 750 hours/month, spins down after 15min idle
# 5. Set these in Render dashboard: https://dashboard.render.com
# =============================================================================
