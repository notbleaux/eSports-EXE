{
  "name": "libre-x-esport-4njz4-tenet",
  "version": "2.0.0",
  "description": "Libre-X-eSport 4NJZ4 TENET Platform — esports simulation and analytics monorepo",
  "private": true,
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "echo 'Game: open project.godot in Godot 4 | API (Phase 3): cd api && npm run dev'",
    "test:firewall": "npm run test --workspace=packages/data-partition-lib",
    "validate:schema": "npm run validate:schema --workspace=packages/stats-schema",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "api"
  ],
  "keywords": ["libre-x", "4njz4", "tenet", "esports", "tactical-fps", "simulation"],
  "license": "MIT"
}
