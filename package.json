{
  "name": "libre-x-esport-4njz4-tenet",
  "version": "2.1.0",
  "description": "Libre-X-eSport 4NJZ4 TENET Platform — esports simulation and analytics monorepo",
  "private": true,
  "packageManager": "npm@10.8.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "echo 'Use: npm run dev:api | npm run dev:web | npm run setup'",
    "dev:api": "cd packages/shared/api && python -m uvicorn main:app --reload --port 8000 --host 0.0.0.0",
    "dev:web": "turbo run dev --filter=web",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "setup:reset": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1 -ResetDatabase",
    "docker:up": "docker-compose up -d db redis",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v",
    "test:firewall": "turbo run test --filter=data-partition-lib",
    "validate:schema": "turbo run validate:schema --filter=stats-schema",
    "typecheck": "turbo run typecheck",
    "test:e2e": "turbo run test:e2e --filter=web",
    "test:unit": "turbo run test --filter=web",
    "mascots:generate": "cd apps/web && npx ts-node scripts/mascot-generator/index.ts",
    "mascots:watch": "cd apps/web && npx ts-node scripts/mascot-generator/watch.ts",
    "mascots:fox": "cd apps/web && npx ts-node scripts/mascot-generator/index.ts --fox",
    "mascots:build": "npm run mascots:generate",
    "prebuild": "npm run mascots:build",
    "optimize:css": "node scripts/optimize-css.js",
    "optimize:svgs": "node scripts/optimize-svgs.js",
    "turbo:login": "turbo login",
    "turbo:link": "turbo link"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "keywords": [
    "libre-x",
    "4njz4",
    "tenet",
    "esports",
    "tactical-fps",
    "simulation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@vitejs/plugin-react": "^4.7.0",
    "cssnano": "^7.1.3",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "svgo": "^4.0.1",
    "terser": "^5.46.1",
    "turbo": "^2.4.4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "minisearch": "^7.2.0"
  },
  "overrides": {
    "scheduler": "^0.23.0"
  }
}
