# Open-Claw Cloud Webhook Configuration
# Copy to .openclaw/.env and fill in your values

# Open-Claw Cloud API
OPENCLAW_WEBHOOK_URL=https://api.openclaw.ai/v1/webhook
OPENCLAW_CLOUD_WEBHOOK_URL=https://api.openclaw.ai/v1/agent/webhook
OPENCLAW_API_KEY=your_openclaw_api_key_here

# Local Webhook Server (fallback)
LOCAL_WEBHOOK_PORT=3001

# Agent Identification
OPENCLAW_AGENT_ID=sator-openclaw-001
KIMI_CLI_AGENT_ID=sator-kimi-cli-001
KIMI_VSCODE_AGENT_ID=sator-vscode-001

# ACP Configuration
ACP_BRIDGE_PORT=8080
ACP_BRIDGE_HOST=localhost

# JLB Integration
JLB_ENABLED=true
JLB_SYNC_INTERVAL_SEC=30
