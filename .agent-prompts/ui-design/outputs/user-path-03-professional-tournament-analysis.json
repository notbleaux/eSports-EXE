{
  "pathId": "user-path-03-professional-tournament-analysis",
  "persona": {
    "name": "professional-analyst",
    "tier": "professional",
    "goals": [
      "Deep statistical analysis of tournaments",
      "Identify meta trends",
      "Create predictive models",
      "Export data for external analysis"
    ],
    "painPoints": [
      "Data scattered across multiple sites",
      "No raw export options",
      "Inconsistent data formats",
      "No historical trend data"
    ]
  },
  "entryPoint": {
    "route": "/valorant/analytics",
    "context": "Research for esports article on VCT Masters",
    "entryMethod": "direct_navigation"
  },
  "journey": {
    "steps": [
      {
        "stepNumber": 1,
        "page": "SATOR Analytics Hub",
        "route": "/valorant/analytics",
        "action": "Views available analytics tools, selects Tournament Analysis",
        "outcome": "Enters tournament query interface",
        "dataRequired": ["available_tools", "recent_tournaments"],
        "uiComponents": ["AnalyticsHub", "ToolGrid", "RecentQueries"]
      },
      {
        "stepNumber": 2,
        "page": "Tournament Query Builder",
        "route": "/valorant/analytics/tournament",
        "action": "Selects VCT Masters 2024, sets filters (playoff stage only)",
        "outcome": "Builds query parameters",
        "dataRequired": ["tournaments_list", "tournament_metadata"],
        "uiComponents": [
          "TournamentSelector",
          "StageFilter",
          "TeamFilter",
          "DateRangePicker",
          "QueryBuilder"
        ]
      },
      {
        "stepNumber": 3,
        "page": "Custom Metrics",
        "route": "/valorant/analytics/tournament?custom=true",
        "action": "Defines custom metrics (First Blood conversion, Eco round win rate)",
        "outcome": "Builds advanced stat query",
        "dataRequired": [],
        "uiComponents": [
          "MetricBuilder",
          "FormulaEditor",
          "PreviewPanel",
          "SavedMetricsLibrary"
        ]
      },
      {
        "stepNumber": 4,
        "page": "Query Results",
        "route": "/valorant/analytics/results",
        "action": "Views aggregated data table, applies sorting and filtering",
        "outcome": "Analyzes tournament statistics",
        "dataRequired": ["aggregated_stats", "custom_metrics_results"],
        "uiComponents": [
          "ResultsTable",
          "ColumnCustomizer",
          "FilterPanel",
          "VisualizationToggle",
          "StatChart"
        ]
      },
      {
        "stepNumber": 5,
        "page": "Visualization",
        "route": "/valorant/analytics/results?view=chart",
        "action": "Switches to chart view, creates trend visualization",
        "outcome": "Visual understanding of data patterns",
        "dataRequired": ["time_series_data"],
        "uiComponents": [
          "ChartBuilder",
          "TrendLine",
          "CorrelationMatrix",
          "ExportChartButton"
        ]
      },
      {
        "stepNumber": 6,
        "page": "Export",
        "route": "/valorant/analytics/export",
        "action": "Exports data as CSV + generates API query link",
        "outcome": "Downloads data, saves API query for automation",
        "dataRequired": [],
        "uiComponents": [
          "ExportOptions",
          "FormatSelector",
          "APIQueryBuilder",
          "DownloadButton",
          "WebhookConfig"
        ]
      }
    ],
    "totalSteps": 6,
    "estimatedTime": "15-20 minutes",
    "decisionPoints": [
      {
        "step": 2,
        "question": "Which tournament and stage?",
        "options": ["Group stage", "Playoffs", "Full tournament", "Custom range"]
      },
      {
        "step": 3,
        "question": "Build custom metric or use preset?",
        "options": ["Preset metrics", "Build custom", "Load saved"]
      },
      {
        "step": 4,
        "question": "View as table or chart?",
        "options": ["Data table", "Chart", "Both (split view)"]
      },
      {
        "step": 6,
        "question": "Export format?",
        "options": ["CSV", "JSON", "Excel", "API endpoint"]
      }
    ]
  },
  "exitPoint": {
    "goal": "Analyzed tournament data and exported for further analysis",
