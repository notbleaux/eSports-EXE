{
  "github.com/render-oss/render-mcp-server": {
    "command": "C:/Program Files/Go/bin/go.exe",
    "args": ["run", "./render-mcp-server/main.go"],
    "env": { "RENDER_API_KEY": "${RENDER_API_KEY}" }
  },
  "manicagency/tenets-mcp-server": {
    "command": "npx",
    "args": ["-y", "@manicagency/tenets-mcp-server"],
    "env": {
      "TENETS_CONFIG": "ROOT_AXIOMS"
    }
  }
}
