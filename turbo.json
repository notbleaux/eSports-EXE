{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "VITE_API_URL",
        "VITE_WS_URL",
        "VITE_APP_ENV",
        "VITE_ANALYTICS_ID",
        "VITE_BASE_PATH"
      ],
      "outputs": ["dist/**", ".vercel/output/**"]
    },
    "libre-x-4njz4-tenet-platform#build": {
      "dependsOn": ["^build"],
      "env": [
        "VITE_API_URL",
        "VITE_WS_URL",
        "VITE_APP_ENV",
        "VITE_ANALYTICS_ID",
        "VITE_BASE_PATH"
      ],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
