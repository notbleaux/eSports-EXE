{
  "_comment": "Field naming mappings for SATOR data pipeline - supports VLR (Valorant) and HLTV (CS2)",
  "version": "1.0.0",
  "last_updated": "2024-03-22",
  
  "sources": {
    "vlr": {
      "name": "VLR.gg",
      "game": "valorant",
      "base_url": "https://www.vlr.gg"
    },
    "hltv": {
      "name": "HLTV.org",
      "game": "cs2",
      "base_url": "https://www.hltv.org"
    },
    "pandascore": {
      "name": "Pandascore",
      "game": "both",
      "base_url": "https://api.pandascore.co"
    }
  },
  
  "match_fields": {
    "match_id": {
      "vlr": "match_id",
      "hltv": "match_id",
      "pandascore": "id",
      "type": "string",
      "description": "Unique match identifier"
    },
    "team_a": {
      "vlr": "team_a",
      "hltv": "team1",
      "pandascore": "opponents[0].opponent.name",
      "type": "string",
      "description": "First team name"
    },
    "team_b": {
      "vlr": "team_b",
      "hltv": "team2",
      "pandascore": "opponents[1].opponent.name",
      "type": "string",
      "description": "Second team name"
    },
    "score_a": {
      "vlr": "score_a",
      "hltv": "team1Score",
      "pandascore": "results[0].score",
      "type": "integer",
      "description": "First team score"
    },
    "score_b": {
      "vlr": "score_b",
      "hltv": "team2Score",
      "pandascore": "results[1].score",
      "type": "integer",
      "description": "Second team score"
    },
    "event_name": {
      "vlr": "event_name",
      "hltv": "event",
      "pandascore": "serie.full_name",
      "type": "string",
      "description": "Tournament/event name"
    },
    "event_id": {
      "vlr": "event_id",
      "hltv": "eventId",
      "pandascore": "serie.id",
      "type": "string",
      "description": "Event identifier"
    },
    "match_date": {
      "vlr": "timestamp",
      "hltv": "date",
      "pandascore": "scheduled_at",
      "type": "datetime",
      "description": "Match start time"
    },
    "format": {
      "vlr": "format",
      "hltv": "format",
      "pandascore": "number_of_games",
      "type": "string",
      "description": "Match format (bo1, bo3, bo5)"
    },
    "status": {
      "vlr": "status",
      "hltv": "status",
      "pandascore": "status",
      "type": "string",
      "description": "Match status"
    }
  },
  
  "player_fields": {
    "player_id": {
      "vlr": "player_id",
      "hltv": "playerId",
      "pandascore": "player.id",
      "type": "string"
    },
    "player_name": {
      "vlr": "player_name",
      "hltv": "nickname",
      "pandascore": "player.name",
      "type": "string"
    },
    "team": {
      "vlr": "team",
      "hltv": "team",
      "pandascore": "team.name",
      "type": "string"
    },
    
    "kills": {
      "vlr": "kills",
      "hltv": "kills",
      "pandascore": "kills",
      "type": "integer",
      "description": "Total kills"
    },
    "deaths": {
      "vlr": "deaths",
      "hltv": "deaths",
      "pandascore": "deaths",
      "type": "integer",
      "description": "Total deaths"
    },
    "assists": {
      "vlr": "assists",
      "hltv": "assists",
      "pandascore": "assists",
      "type": "integer",
      "description": "Total assists"
    },
    
    "adr": {
      "vlr": "damage_made / rounds_played",
      "hltv": "adr",
      "pandascore": "adr",
      "type": "float",
      "description": "Average Damage per Round"
    },
    "kast": {
      "vlr": "kast_pct",
      "hltv": "kast",
      "pandascore": "kast",
      "type": "float",
      "description": "Kill, Assist, Survive, Trade percentage"
    },
    "rating": {
      "vlr": "rating",
      "hltv": "rating",
      "pandascore": "rating",
      "type": "float",
      "description": "Performance rating"
    },
    
    "headshot_percent": {
      "vlr": "headshot_pct",
      "hltv": "hsPercent",
      "pandascore": "hs_percent",
      "type": "float",
      "description": "Headshot percentage"
    },
    "first_kills": {
      "vlr": "first_bloods",
      "hltv": "fk",
      "pandascore": "first_kills",
      "type": "integer"
    },
    "first_deaths": {
      "vlr": "first_deaths",
      "hltv": "fd",
      "pandascore": "first_deaths",
      "type": "integer"
    }
  },
  
  "game_specific": {
    "valorant": {
      "agent": {
        "vlr": "agent",
        "pandascore": "character.name",
        "type": "string",
        "description": "Agent/character played"
      },
      "acs": {
        "vlr": "acs",
        "pandascore": "acs",
        "type": "float",
        "description": "Average Combat Score"
      },
      "econ_rating": {
        "vlr": "econ_rating",
        "pandascore": "econ_rating",
        "type": "float",
        "description": "Economic rating"
      },
      "fb": {
        "vlr": "fb",
        "pandascore": "first_bloods",
        "type": "integer",
        "description": "First bloods"
      },
      "plants": {
        "vlr": "plants",
        "pandascore": "plants",
        "type": "integer"
      },
      "defuses": {
        "vlr": "defuses",
        "pandascore": "defuses",
        "type": "integer"
      }
    },
    
    "cs2": {
      "fk_diff": {
        "hltv": "fkDiff",
        "pandascore": "fk_diff",
        "type": "integer",
        "description": "First kill difference (FK - FD)"
      },
      "opening_kill_ratio": {
        "hltv": "openingKills / openingDeaths",
        "type": "float",
        "description": "Opening kill to death ratio"
      },
      "clutches_won": {
        "hltv": "clutchesWon",
        "pandascore": "clutches",
        "type": "integer"
      },
      "rounds_played": {
        "hltv": "roundsPlayed",
        "type": "integer"
      },
      "kpr": {
        "hltv": "kills / roundsPlayed",
        "type": "float",
        "description": "Kills per round"
      },
      "dpr": {
        "hltv": "deaths / roundsPlayed",
        "type": "float",
        "description": "Deaths per round"
      },
      "apr": {
        "hltv": "assists / roundsPlayed",
        "type": "float",
        "description": "Assists per round"
      },
      "impact": {
        "hltv": "impact",
        "type": "float",
        "description": "HLTV impact rating"
      }
    }
  },
  
  "map_fields": {
    "map_name": {
      "vlr": "map",
      "hltv": "name",
      "pandascore": "map.name",
      "type": "string"
    },
    "map_score_a": {
      "vlr": "team_a_score",
      "hltv": "team1Score",
      "pandascore": "score[0]",
      "type": "integer"
    },
    "map_score_b": {
      "vlr": "team_b_score",
      "hltv": "team2Score",
      "pandascore": "score[1]",
      "type": "integer"
    },
    "duration": {
      "vlr": "duration",
      "hltv": "duration",
      "pandascore": "finished_at - started_at",
      "type": "integer",
      "description": "Match duration in seconds"
    },
    "overtime": {
      "vlr": "overtime",
      "hltv": "overtime",
      "type": "boolean"
    }
  },
  
  "calculated_fields": {
    "kdr": {
      "formula": "kills / max(deaths, 1)",
      "type": "float",
      "description": "Kill/Death ratio"
    },
    "kda": {
      "formula": "(kills + assists) / max(deaths, 1)",
      "type": "float",
      "description": "Kill/Death/Assist ratio"
    },
    "fk_diff": {
      "formula": "first_kills - first_deaths",
      "type": "integer",
      "description": "First kill difference"
    },
    "impact_estimate": {
      "formula": "(2.13 * kpr) + (0.42 * fk_diff / rounds) - 0.41",
      "type": "float",
      "description": "Estimated impact (HLTV formula)"
    }
  },
  
  "normalization_rules": {
    "map_names": {
      "description": "Normalize map names across sources",
      "rules": {
        "dust2": ["dust2", "de_dust2", "d2", "Dust II"],
        "mirage": ["mirage", "de_mirage", "mrg"],
        "inferno": ["inferno", "de_inferno", "inf"],
        "nuke": ["nuke", "de_nuke", "nk"],
        "overpass": ["overpass", "de_overpass", "op"],
        "vertigo": ["vertigo", "de_vertigo", "vtg"],
        "ancient": ["ancient", "de_ancient", "anc"],
        "anubis": ["anubis", "de_anubis", "anb"],
        "ascent": ["ascent", "Ascent"],
        "bind": ["bind", "Bind"],
        "breeze": ["breeze", "Breeze"],
        "fracture": ["fracture", "Fracture"],
        "haven": ["haven", "Haven"],
        "icebox": ["icebox", "Icebox"],
        "lotus": ["lotus", "Lotus"],
        "pearl": ["pearl", "Pearl"],
        "split": ["split", "Split"],
        "sunset": ["sunset", "Sunset"]
      }
    },
    "team_names": {
      "description": "Normalize team names",
      "rules": {
        "case": "title",
        "strip_suffixes": ["esports", "gaming", "team", "club"],
        "aliases": {
          "faze": ["faze", "faze clan", "fazeclan"],
          "navi": ["navi", "natus vincere", "natus_vincere"],
          "g2": ["g2", "g2 esports", "g2esports"],
          "vitality": ["vitality", "team vitality", "teamvitality"],
          "astralis": ["astralis"],
          "liquid": ["liquid", "team liquid", "teamliquid"],
          "furia": ["furia", "furia esports", "furiaesports"],
          "sentinels": ["sentinels", "sen"],
          "loud": ["loud", "loud esports"],
          "eg": ["eg", "evil geniuses", "evilgeniuses"]
        }
      }
    }
  },
  
  "data_quality": {
    "required_fields": ["match_id", "team_a", "team_b", "score_a", "score_b"],
    "player_required": ["player_id", "player_name", "kills", "deaths"],
    "validation_rules": {
      "score_range": {"min": 0, "max": 32},
      "rating_range": {"min": 0.0, "max": 3.0},
      "kast_range": {"min": 0.0, "max": 100.0},
      "adr_range": {"min": 0.0, "max": 300.0}
    }
  }
}
