# Copy this file to .env — NEVER commit .env

# Database
DATABASE_URL=postgresql://axiom:changeme@localhost:5432/axiom_esports
POSTGRES_USER=axiom
POSTGRES_PASSWORD=changeme

# Extraction
VLR_RATE_LIMIT=2.0
RAW_STORAGE_PATH=data/raw_extractions

# External validation (optional)
HLTV_API_KEY=
GRID_API_KEY=
LIQUIPEDIA_API_KEY=

# GitHub Actions
GITHUB_TOKEN=

# Data retention
DATA_RETENTION_DAYS=730

# Analytics
TRAIN_CUTOFF_DATE=2024-01-01
MIN_MAPS_TRAINING=50
MAX_MAPS_CEILING=200

# ============================================
# TRINITY + OPERA Architecture Components
# ============================================

# Component A: SQLite Task Queue (TRINITY Edge)
QUEUE_DB_PATH=/var/lib/sator/queue.db
QUEUE_TIMEOUT=30
QUEUE_MAX_RETRIES=3

# Component B: PostgreSQL (Primary OLTP)
# DATABASE_URL already defined above

# Component C: Turso Edge (optional - distributed SQLite)
TURSO_DATABASE_URL=libsql://sator-[username].turso.io
TURSO_AUTH_TOKEN=[turso-token]
TURSO_RETENTION_DAYS=540
TURSO_SYNC_INTERVAL=300

# Component D: TiDB OPERA (Analytics/OLAP)
TIDB_HOST=gateway01.us-west-2.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=[tidb-user]
TIDB_PASSWORD=[tidb-password]
TIDB_DATABASE=opera
TIDB_SSL_MODE=VERIFY_IDENTITY

# ============================================
# Harvester Configuration
# ============================================

# VLR.gg Rate Limiting (requests per second)
VLR_RATE_LIMIT=2
VLR_MAX_RETRIES=3
VLR_BACKOFF_BASE=2
VLR_TIMEOUT=30

# Worker Process Configuration
HARVEST_WORKERS=2
HARVEST_MAX_WORKERS=4
HARVEST_QUEUE_SIZE=100
HARVEST_BATCH_SIZE=10

# Orchestrator Settings
ORCHESTRATOR_HEARTBEAT_INTERVAL=60
ORCHESTRATOR_WORKER_TIMEOUT=300
ORCHESTRATOR_MAX_FAILED_JOBS=5

# Log Configuration
LOG_LEVEL=INFO
LOG_FILE=/var/log/sator/harvest.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Data Retention (days)
QUEUE_RETENTION_DAYS=30
OPERA_RETENTION_DAYS=730
TURSO_RETENTION_DAYS=540
