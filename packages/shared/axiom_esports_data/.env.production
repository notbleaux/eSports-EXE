# =============================================================================
# SATOR API - Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local and fill in actual values
# NEVER commit .env.production.local to git
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE - Supabase PostgreSQL
# -----------------------------------------------------------------------------
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Alternative: Use connection pooler for better performance
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Configuration (for future auth/ realtime features)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# API SERVER CONFIGURATION
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Render free tier: Use 1 worker to stay within 512MB RAM limit
# Upgrade to 2-4 workers on paid tiers
API_WORKERS=1

# Application metadata
APP_NAME=SATOR-API
APP_VERSION=0.1.0
APP_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# CORS & SECURITY
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Add your Vercel deployment URL after initial deploy
CORS_ORIGINS=https://sator-web.vercel.app,https://satorx.github.io,http://localhost:3000,http://localhost:5173

# Rate limiting (requests per minute per IP)
# Keep conservative on free tier: 30 req/min = 1 request every 2 seconds
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# API Key for admin endpoints (generate a strong random string)
# ADMIN_API_KEY=your_secure_random_admin_key_here

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Formats: json (production), text (development)
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# DATA & ANALYTICS CONFIGURATION
# -----------------------------------------------------------------------------
# Data retention in days (Supabase free tier: be conservative)
# 365 days = ~1 year of match data
DATA_RETENTION_DAYS=365

# Training cutoff for analytics
TRAIN_CUTOFF_DATE=2024-01-01

# Minimum maps for statistical confidence
MIN_MAPS_TRAINING=50
MAX_MAPS_CEILING=200

# -----------------------------------------------------------------------------
# COLD START MITIGATION (Render Free Tier)
# -----------------------------------------------------------------------------
# Health check endpoint to keep warm
WARMUP_ENDPOINT=/health

# Ping interval in minutes (must be < 15 to prevent spin-down)
WARMUP_INTERVAL_MINUTES=10

# Enable warmup worker
ENABLE_WARMUP=true

# -----------------------------------------------------------------------------
# OPTIONAL: EXTERNAL API KEYS
# -----------------------------------------------------------------------------
# These are optional for basic operation, required for data extraction
VLR_RATE_LIMIT=2.0
RAW_STORAGE_PATH=/tmp/raw_extractions

# HLTV_API_KEY=
# GRID_API_KEY=
# LIQUIPEDIA_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking (recommended for production)
# SENTRY_DSN=https://your-sentry-dsn-here

# -----------------------------------------------------------------------------
# SUPABASE FREE TIER LIMITS (for reference)
# -----------------------------------------------------------------------------
# Storage: 500MB total
# Row Reads: 2,000,000/month
# Bandwidth: 500MB/month egress
# Max Connections: 30
#
# Monitor usage at: https://app.supabase.com/project/YOUR_PROJECT_REF/usage
