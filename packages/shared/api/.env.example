[Ver002.000]
# SATOR API Environment Configuration
# ===================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sator

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional: Redis (for rate limiting, caching)
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Environment
APP_ENVIRONMENT=production
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=https://notbleaux.github.io,https://notbleaux.github.io/eSports-EXE,http://localhost:3000,http://localhost:5173

# OAuth — Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-api.onrender.com/v1/oauth/google/callback

# OAuth — Discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-api.onrender.com/v1/oauth/discord/callback

# PandaScore
PANDASCORE_API_KEY=pc_live_...
PANDASCORE_WEBHOOK_SECRET=your-webhook-secret

# Sentry (optional — leave blank to disable)
SENTRY_DSN=https://your-key@sentry.io/your-project-id
