[Ver001.000]
# SATOR API Environment Configuration
# ===================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sator

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional: Redis (for rate limiting, caching)
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Environment
APP_ENVIRONMENT=production
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=https://notbleaux.github.io,https://notbleaux.github.io/eSports-EXE,http://localhost:3000,http://localhost:5173
