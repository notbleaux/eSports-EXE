# Archival System Configuration
# Copy to .env.archival and customize for your environment

# =============================================================================
# Storage Configuration
# =============================================================================

# Local storage directory for frames
ARCHIVE_LOCAL_DATA_DIR=/data/frames

# Storage backend type: local | s3
ARCHIVE_STORAGE_BACKEND=local

# =============================================================================
# S3 Backend Configuration (optional, for Phase 2)
# Uncomment and configure when using S3 backend
# =============================================================================

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=njz-archival-frames

# Optional: Custom S3 endpoint (for MinIO, etc.)
# S3_ENDPOINT_URL=https://s3.custom.endpoint

# Optional: S3 path prefix for all objects
# S3_PATH_PREFIX=frames/

# =============================================================================
# Retention & Lifecycle
# =============================================================================

# Default retention period for garbage collection (days)
DEFAULT_RETENTION_DAYS=90

# Maximum TTL for pinned frames (days)
MAX_PIN_TTL_DAYS=365

# =============================================================================
# Rate Limiting & Limits
# =============================================================================

# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Maximum frames per batch upload
MAX_FRAMES_PER_BATCH=1000

# Maximum concurrent uploads
MAX_CONCURRENT_UPLOADS=10

# =============================================================================
# Metrics & Observability
# =============================================================================

# Enable Prometheus metrics endpoint
ENABLE_PROMETHEUS=true

# Metrics port (if separate from API port)
METRICS_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable structured JSON logging
ENABLE_STRUCTLOG=true

# =============================================================================
# Database & Cache
# =============================================================================

# Database connection (inherited from main API or override)
# DATABASE_URL=postgresql://user:pass@localhost:5432/sator

# Redis connection (inherited from main API or override)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================

# Comma-separated list of admin usernames
ARCHIVE_ADMIN_USERS=admin

# Enable audit logging for all operations
ENABLE_AUDIT_LOG=true

# =============================================================================
# Performance Tuning
# =============================================================================

# Database connection pool size
DB_POOL_SIZE=10

# GC batch size for deletion operations
GC_BATCH_SIZE=1000

# Cache TTL for frame queries (seconds)
FRAME_CACHE_TTL=300
