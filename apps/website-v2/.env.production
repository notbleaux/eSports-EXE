# Production Environment Variables
# Libre-X-eSport 4NJZ4 TENET Platform
# [Ver001.000]

# ============================================
# API Configuration
# ============================================
VITE_API_URL=https://api.libre-x-esport.com/v1
VITE_WS_URL=wss://api.libre-x-esport.com/v1/ws

# ============================================
# Sentry Error Tracking
# Get DSN from: https://sentry.io/settings/projects/4njz4-tenet-platform/keys/
# ============================================
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/yyyyyyyy

# ============================================
# Application Configuration
# ============================================
VITE_APP_NAME=Libre-X-eSport
VITE_APP_VERSION=2.1.0
VITE_APP_ENVIRONMENT=production

# ============================================
# Feature Flags
# ============================================
VITE_FEATURE_WEBSOCKET=true
VITE_FEATURE_ML_PREDICTIONS=true
VITE_FEATURE_LIVE_DATA=true

# ============================================
# Analytics & Monitoring
# ============================================
VITE_ANALYTICS_ENABLED=true
VITE_PERFORMANCE_MONITORING=true

# ============================================
# Build Information (injected at build time)
# ============================================
VITE_BUILD_ID=local
VITE_BUILD_TIME=2026-03-16T00:00:00Z
