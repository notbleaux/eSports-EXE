{
  "name": "@njzitegeist/web",
  "version": "2.1.0",
  "description": "NJZiteGeisTe — Community eSports analytics platform (Valorant & CS2)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test --config=playwright-visual.config.ts",
    "test:visual:update": "cross-env UPDATE_VISUAL_BASELINES=1 playwright test --config=playwright-visual.config.ts -g 'Update all baselines'",
    "test:visual:report": "playwright show-report playwright-report/visual",
    "test:visual:fox": "playwright test --config=playwright-visual.config.ts -g 'Fox'",
    "test:visual:bear": "playwright test --config=playwright-visual.config.ts -g 'Dropout Bear'",
    "test:visual:bunny": "playwright test --config=playwright-visual.config.ts -g 'NJ Bunny'",
    "test:visual:baseline:generate": "node tests/visual/scripts/generate-baselines.js",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "build:analyze": "pnpm run build && pnpm run analyze:bundle"
  },
  "dependencies": {
    "@njz/types": "workspace:*",
    "@gsap/react": "^2.0.0",
    "@react-three/drei": "^9.90.0",
    "@react-three/fiber": "^8.15.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.22",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "@use-gesture/react": "^10.3.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^11.0.0",
    "gsap": "^3.12.0",
    "lucide-react": "^0.294.0",
    "onnxruntime-web": "^1.20.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "terser": "^5.46.1",
    "three": "^0.159.0",
    "three-mesh-bvh": "^0.8.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-grid-layout": "^1.3.6",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^14.0.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.0",
    "ws": "^8.14.0"
  }
}
