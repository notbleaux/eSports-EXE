# [Ver001.000] Website-V2 Environment Configuration Example
# Libre-X-eSport 4NJZ4 TENET Platform
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# API CONFIGURATION
# =============================================================================
VITE_API_URL=https://your-api-url.com/v1
VITE_WS_URL=wss://your-api-url.com/v1/ws

# =============================================================================
# SUPABASE
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# PANDASCORE
# =============================================================================
VITE_PANDASCORE_API_KEY=your-pandascore-api-key

# =============================================================================
# APP CONFIG
# =============================================================================
VITE_APP_ENVIRONMENT=development
VITE_APP_VERSION=2.0.0
VITE_ENABLE_MOCK_DATA=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# ML Features
VITE_ENABLE_ML=false
VITE_ENABLE_MODEL_REGISTRY=false

# UI Features
VITE_ENABLE_NEW_UI=false

# Beta/Experimental Features
VITE_ENABLE_BETA=false

# =============================================================================
# VERCEL PROJECT (optional - for CLI deployments)
# =============================================================================
# VERCEL_PROJECT_ID=your-vercel-project-id
