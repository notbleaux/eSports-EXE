{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "TaskBidRequest": {
        "properties": {
          "message": {
            "anyOf": [
              {
                "maxLength": 2048,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          }
        },
        "title": "TaskBidRequest",
        "type": "object"
      },
      "TaskCreateRequest": {
        "properties": {
          "description": {
            "maxLength": 4096,
            "minLength": 1,
            "title": "Description",
            "type": "string"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          }
        },
        "required": [
          "description"
        ],
        "title": "TaskCreateRequest",
        "type": "object"
      },
      "TaskSubmitRequest": {
        "properties": {
          "complete": {
            "description": "True \u2192 COMPLETED; False \u2192 PARTIAL_PENDING_HANDOFF",
            "title": "Complete",
            "type": "boolean"
          },
          "content": {
            "maxLength": 65536,
            "minLength": 1,
            "title": "Content",
            "type": "string"
          }
        },
        "required": [
          "content",
          "complete"
        ],
        "title": "TaskSubmitRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Zero-Trust agent coordination gateway \u2014 ECDSA-signed task lifecycle (/tasks/create, /bid, /submit) backed by SQLite WAL with optional Supabase mirror + Redis Pub/Sub event bus + telemetry counters.",
    "title": "ZSXT Agent-Coordination Gateway",
    "version": "0.7.0-phase7-telemetry"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Liveness probe \u2014 bypasses auth middleware via PUBLIC_PATHS.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/tasks/create": {
      "post": {
        "description": "Post a new task to the blackboard.\n\nThe middleware has already verified the caller's signature; `agent_id`\non `request.state` is trusted.",
        "operationId": "create_task_tasks_create_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Create Task Tasks Create Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Task"
      }
    },
    "/tasks/{task_id}/bid": {
      "post": {
        "description": "Claim an OPEN task (or accept a hand-off from PARTIAL_PENDING_HANDOFF).\n\nFirst bid wins \u2014 Phase 5 will swap this for a multi-bidder auction.",
        "operationId": "bid_on_task_tasks__task_id__bid_post",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "title": "Task Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskBidRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Bid On Task Tasks  Task Id  Bid Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Bid On Task"
      }
    },
    "/tasks/{task_id}/submit": {
      "post": {
        "description": "Submit work for a task you currently claim.\n\n`complete=True` \u2192 COMPLETED; `complete=False` \u2192 PARTIAL_PENDING_HANDOFF\n(the task becomes biddable again so another agent can take it over).",
        "operationId": "submit_task_tasks__task_id__submit_post",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "title": "Task Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskSubmitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Submit Task Tasks  Task Id  Submit Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit Task"
      }
    },
    "/telemetry/summary": {
      "get": {
        "description": "Per-agent + total event counts aggregated from the Phase 5 bus.\n\nPublic endpoint (no signature required) \u2014 read-only over the local\n`telemetry_counters` table. Returns zeros when the bus is unwired.",
        "operationId": "telemetry_summary_telemetry_summary_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Telemetry Summary Telemetry Summary Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Telemetry Summary"
      }
    }
  }
}
