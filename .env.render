# [Ver001.000]
# Render Deployment Environment Variables Template
# Copy these values to your Render dashboard Environment section
# DO NOT commit this file with real values to git!
# =============================================================================

# =============================================================================
# DATABASE (Supabase PostgreSQL - Free Tier)
# =============================================================================
# Get from Supabase Dashboard: Project Settings > Database > Connection String
# Use the "Transaction pooler" connection string for serverless functions
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# =============================================================================
# REDIS (Upstash Redis - Free Tier)
# =============================================================================
# Get from Upstash Console: Redis Database > REST API > Connect
# Use the rediss:// URL with TLS (note the double 's' for secure)
REDIS_URL=rediss://default:[password]@[host]:6379

# =============================================================================
# SECURITY KEYS (Generate with: openssl rand -hex 32)
# =============================================================================
# JWT Secret for authentication tokens
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32

# TOTP Encryption Key for 2FA
TOTP_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# General encryption key for sensitive data
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
# Pandascore API Key (Get from: https://pandascore.co/dashboard)
# Free tier: 1000 calls/day, 1 call/second
PANDASCORE_API_KEY=your_pandascore_api_key_here

# Riot Games API Key (Get from: https://developer.riotgames.com/)
RIOT_API_KEY=your_riot_api_key_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment
APP_ENVIRONMENT=production
APP_NAME=SATOR-API
APP_VERSION=2.1.0

# Logging
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
# Update with your actual Vercel deployment URL
CORS_ORIGINS=https://sator-platform.vercel.app,https://sator-web.onrender.com

# =============================================================================
# DATABASE POOL CONFIGURATION (Free Tier Optimized)
# =============================================================================
# Keep these values low for free tier
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=5

# =============================================================================
# RENDER-SPECIFIC (Auto-populated by Render)
# =============================================================================
# Render sets PORT automatically - do not override
# PORT=10000

# =============================================================================
# KEY GENERATION INSTRUCTIONS
# =============================================================================
# Run these commands to generate secure keys:
#
# JWT_SECRET_KEY:
#   openssl rand -hex 32
#
# TOTP_ENCRYPTION_KEY:
#   openssl rand -hex 32
#
# ENCRYPTION_KEY:
#   openssl rand -hex 32
#
# =============================================================================
